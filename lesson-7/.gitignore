# Local .terraform directories (contains provider binaries and modules)
.terraform/

# .tfstate files (sensitive local state)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (contain sensitive data like passwords/keys)
*.tfvars
*.tfvars.json

# Ignore override files used for local testing
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created during terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files (typically contain sensitive secrets in plain text)
*tfplan*
